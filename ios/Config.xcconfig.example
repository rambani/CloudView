// Cloudoodle — Build Configuration
// ─────────────────────────────────────────────────────────────────────────────
// 1. Copy this file to Config.xcconfig (same directory)
// 2. Fill in your values below
// 3. Config.xcconfig is gitignored — never commit real values
//
// After filling in, run: xcodegen generate
// ─────────────────────────────────────────────────────────────────────────────

// Supabase project URL — found in Settings → API in your Supabase dashboard
SUPABASE_URL = https://xxxxxxxxxxxxxxxxxxxx.supabase.co

// Supabase anon key (safe for client-side use — RLS protects your data)
SUPABASE_ANON_KEY = eyJ...

// Sentry DSN — create a project at https://sentry.io (free tier available)
// Leave blank to disable crash reporting
SENTRY_DSN =

// Note: Gemini + OpenAI API keys are NOT in the client anymore. They live
// as secrets on the `develop-polaroid` Supabase edge function:
//   supabase secrets set GEMINI_API_KEY=<key>
//   supabase secrets set OPENAI_API_KEY=sk-...
//
// Earlier builds bundled them into Info.plist via Config.xcconfig; that
// path is removed in favor of the server-side proxy.
