// Template for developer-local secrets.
//
// Setup:
//   1. cp Config/Secrets.xcconfig.example Config/Secrets.xcconfig
//   2. Fill in the values below.
//   3. Build. (Secrets.xcconfig is gitignored; do not commit your real values.)
//
// CI/CD does not use this file directly — the workflow writes Secrets.xcconfig
// from a repository secret instead.

// OpenWeatherMap API key. Free tier available at:
// https://openweathermap.org/api
OPEN_WEATHER_API_KEY =
